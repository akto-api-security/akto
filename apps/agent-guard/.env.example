# =============================================================================
# Agent Guard — single env template
# =============================================================================
#
#   cp .env.example .env          # fill secrets once
#
# Used by:
#   • docker compose              → reads apps/agent-guard/.env
#   • Cloudflare local dev        → cp .env python-service/worker-py/.dev.vars
#   • wrangler deploy secrets     → ./scripts/set-secrets.sh (from worker-py/)
#
# Cloudflare Workers: leave ANONYMIZER_URL empty (uses service binding).
# Docker compose: ANONYMIZER_URL is overridden in docker-compose.yml.
#
# Local scanners work without secrets. Cascade scanners need Vertex creds below.
# =============================================================================

# --- Docker compose (image tags; use "local" to build from source) ---
AGENT_GUARD_WORKER_TAG=local
AGENT_GUARD_ANONYMIZER_TAG=local
AGENT_GUARD_EXECUTOR_TAG=local

# --- Legacy ONNX container only (see PRODUCTION.md) ---
# FORCE_LLM_MODE=true
# SCANNER_LLM_PROVIDER=
# VERTEX_AI_PROJECT=
# VERTEX_AI_LOCATION=
# VERTEX_AI_ENDPOINT_ID=
# VERTEX_AI_SA_KEY_JSON=

# --- Portable only (docker / Azure / K8s). Leave empty for Cloudflare. ---
ANONYMIZER_URL=

# --- Vertex — Qwen3Guard (tier-1 fast filter) ---
QWEN3GUARD_SA_KEY_JSON=
QWEN3GUARD_PROJECT=
QWEN3GUARD_LOCATION=
QWEN3GUARD_ENDPOINT_ID=
QWEN3GUARD_DEDICATED_DNS=

# --- Vertex — Gemma (final arbiter) ---
GEMMA_VERTEX_SA_KEY_JSON=
GEMMA_VERTEX_PROJECT=
GEMMA_VERTEX_LOCATION=
GEMMA_VERTEX_ENDPOINT_ID=
GEMMA_VERTEX_DEDICATED_DNS=

# --- Optional LLM providers (only if used in modelConfigs) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_COMPATIBLE_BASE_URL=

# --- Optional integrations ---
SLACK_WEBHOOK_URL=
DATABASE_ABSTRACTOR_SERVICE_URL=
DATABASE_ABSTRACTOR_SERVICE_TOKEN=
# Seconds between metric pushes to database-abstractor. Default 60s.
METRICS_PUSH_INTERVAL_SEC=

# --- Cascade default modelMap (JSON). Empty → built-in qwen + gemma arbiter. ---
# executor-v2 (wrangler.jsonc): usually leave empty.
# executor (wrangler-exec.jsonc): set a different map for that deployment only.
# DEFAULT_MODEL_CONFIG_JSON={"modelConfigs":[{"provider":"qwen3guard","modelRole":"FAST_THREAT_FILTER","safeDecisionThreshold":0.9,"timeoutMs":5000},{"provider":"gemma_vertexai","modelRole":"FINAL_ARBITER","safeDecisionThreshold":0.9,"timeoutMs":30000}],"parallelExecution":false,"storeAllResults":false}
DEFAULT_MODEL_CONFIG_JSON=

# --- Cascade (MODEL) backpressure — fail-open the Vertex cascade when its avg
#     latency is high. Protects against Vertex/GPU degradation. ---
# AGW_CASCADE_BACKPRESSURE_ENABLED=true
# AGW_CASCADE_BACKPRESSURE_AVG_LATENCY_MS=8000
# AGW_CASCADE_BACKPRESSURE_MIN_SAMPLES=5
# AGW_CASCADE_BACKPRESSURE_WINDOW=50
# AGW_CASCADE_BACKPRESSURE_TTL_SECONDS=30

# --- Scan diagnostics (load-test / backpressure verification) ---
# AGW_SCAN_DIAGNOSTICS=true — verbose per-scan paths + in-flight counts
# AGW_LOG_LEVEL=info — required for [scan-diag] lines in docker logs (default: info)
# LOG_LEVEL=info — alias for AGW_LOG_LEVEL

# --- Anonymizer diagnostics (Presidio sidecar; load-test latency) ---
# Baked into the anonymizer image by default (info + diagnostics on + slow_ms=200).
# Override here or in infra compose only if you need quieter logs.
# ANONYMIZER_DIAGNOSTICS=false
# ANONYMIZER_LOG_LEVEL=info
# ANONYMIZER_SLOW_MS=200
# ANONYMIZER_WORKERS=4
