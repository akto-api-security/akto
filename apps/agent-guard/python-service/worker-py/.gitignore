# Local secrets — never commit (any .dev.vars / .dev.vars.<env>), but keep the
# .example templates tracked.
.dev.vars
.dev.vars.*
!.dev.vars.example
!.dev.vars.exec.example

# uv / pywrangler / pyodide build artifacts
.venv/
.venv-workers/
python_modules/
.wrangler/
uv.lock

# test artifacts
.pytest_cache/
__pycache__/
*.pyc
