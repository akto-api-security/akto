{
	"name": "akto-agent-guard-executor-v2",
	"main": "src/entry.py",
	"compatibility_date": "2025-06-23",
	"compatibility_flags": [
		"python_workers"
	],
	"workers_dev": true,
	"observability": {
		"enabled": true
	},
	"services": [
		{
			"binding": "ANONYMIZER_WORKER",
			"service": "akto-anonymizer-worker"
		}
	],
	"vectorize": [
		{
			"binding": "VECTORIZE",
			"index_name": "guardrails-shadow-cache",
			// Vectorize has no local emulator; remote binds `wrangler dev` to the real index.
			"remote": true
		}
	]
}