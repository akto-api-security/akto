# Server configuration
SERVER_PORT=8080

# Database abstractor service
DATABASE_ABSTRACTOR_SERVICE_URL=http://database-abstractor:9000
DATABASE_ABSTRACTOR_SERVICE_TOKEN=your-jwt-token-here

# Agent Guard Engine URL for NLP model computations
AGENT_GUARD_ENGINE_URL=https://akto-agent-guard-engine.billing-53a.workers.dev

# Optional per-endpoint JSON field paths when dashboard guardrailSchema is unset.
# Format: METHOD:PATH:requestPath,responsePath (semicolon-separated entries).
# Multiple paths per side are pipe-separated; first match wins.
# Example: POST:/v1/chat/completions:messages.role=user.content|messages.role=user.content.0.text,choices.0.message.content
# GUARDRAIL_FIELD_MAPPING=

# Threat backend service for publishing results to dashboard
THREAT_BACKEND_URL=https://tbs.akto.io
THREAT_BACKEND_TOKEN=your-akto-api-token-here

# --- PII dummy redaction (before scanner / LLM / semantic cache) ------------
# Normalizes PII to dummy placeholders (e.g. alice@x.com -> aaaa@aaaa.com) so
# cache keys and downstream scanners see stable text. Implemented in mcp-endpoint-shield.
# GUARDRAILS_PII_ENGINE=hyperscan          # default; sync PII policy rules + dummy redaction; needs -tags hyperscan + libvectorscan
# GUARDRAILS_PII_ENGINE=regexp             # force sequential Go regexp (no native lib; local dev without vectorscan)
# GUARDRAILS_SKIP_PII_REDACTION=true       # load-test only: skip dummy redaction before scanners/cache
# GUARDRAILS_SKIP_PII_SYNC=true            # load-test only: skip sync piiFilter policy rules (block/redact/warn)

# Logging
LOG_LEVEL=info
GIN_MODE=release

# --- Scan backpressure breaker --------------------------------------------
# Self-healing circuit breaker over the downstream scan path (agent-guard /scan,
# reached via the mcp processor). When the recent average latency of
# ProcessRequest/ResponseParallel crosses AVG_LATENCY_MS, new requests fail-open
# (Allowed) instead of blocking on the slow dependency, preserving throughput.
# Mirrors agent-guard's LatencyBreaker. Recovers on its own once samples age out
# past TTL. State is per-process. GET /backpressure exposes the live snapshot.
# GUARDRAILS_BACKPRESSURE_ENABLED=true
# GUARDRAILS_BACKPRESSURE_AVG_LATENCY_MS=8000   # trip threshold (rolling avg, ms)
# GUARDRAILS_BACKPRESSURE_MIN_SAMPLES=5         # min recent samples before it can trip
# GUARDRAILS_BACKPRESSURE_WINDOW=50             # max samples retained
# GUARDRAILS_BACKPRESSURE_TTL_SECONDS=30        # sample staleness / self-heal window

# --- Scan inflight limiter -------------------------------------------------
# Bounded concurrency cap over the same agent-guard /scan path, complementing the
# latency breaker. The breaker only reacts to *completed*-call latency, so it is
# blind for one scan duration and admits an unbounded flood on a sharp load step
# (and on each self-heal probe). This caps concurrent scans and fails open
# (Allowed) the instant it is at capacity, shedding excess load synchronously.
# Counters are exposed on GET /backpressure (inflight_in_use / inflight_rejected_total).
# GUARDRAILS_SCAN_INFLIGHT_ENABLED=true
# GUARDRAILS_SCAN_MAX_INFLIGHT=256              # max concurrent remote scans; <=0 disables

# --- Validation deadline ---------------------------------------------------
# One absolute deadline over the whole synchronous validate path (all parallel
# policy goroutines, their async scanner waits, and each /scan call). Keep it
# BELOW the caller's client timeout (data-ingestion GUARDRAILS_CLIENT_TIMEOUT_MS,
# default 3000) so a slow/saturated scanner fails open here before the caller
# gives up — otherwise the caller times out while this side is still waiting.
# <=0 disables the bound (falls back to the per-async-batch 5s timeout).
# GUARDRAILS_VALIDATION_TIMEOUT_MS=2500

# --- Semantic cache (in front of agent-guard) ------------------------------
# Per-scanner + per-account semantic cache that sits BEFORE the backpressure
# breaker/inflight limiter and the agent-guard /scan call. On a fresh cache hit
# it serves the known verdict (including a known block) WITHOUT calling agent-
# guard — so when agent-guard is load-shed the cache still enforces known
# decisions instead of blindly failing open. A miss/error always falls through
# to the real scan; the whole subsystem is fail-open (no REDIS_URL / no embedder
# ⇒ clean miss). Requires Redis with the RediSearch module and the embedder
# service (all-MiniLM-L6-v2, 384-dim, /embed). Keys are partitioned by account
# so one tenant's verdict is never served to another.
#
# CACHE_MODE=off                                # off | observe (warm only) | decide (serve). Default off.
# REDIS_URL=redis://redis-stack:6379            # Redis w/ RediSearch; unset ⇒ cache disabled (fail-open)
# EMBEDDER_URL=http://embedder:8094             # agent-guard embedder container; unset ⇒ no fuzzy lookup
# CACHE_DISTANCE_THRESHOLD=0.15                 # max COSINE distance to serve a cached SAFE verdict (fuzzy)
# CACHE_BLOCK_DISTANCE_THRESHOLD=0.0            # max distance to serve a cached BLOCK (0.0 ⇒ exact repeat only)
# CACHE_TTL_SECONDS=21600                       # entry freshness / native Redis EXPIRE (6h)
# CACHE_REDIS_INDEX=guardrails_shadow_cache     # RediSearch index name (shared with agent-guard)
# --- embedder backpressure (skips the fuzzy embed when the embedder is slow) ---
# CACHE_EMBED_BACKPRESSURE_ENABLED=true
# CACHE_EMBED_BACKPRESSURE_AVG_LATENCY_MS=2000  # trip threshold (rolling avg, ms)
# CACHE_EMBED_BACKPRESSURE_MIN_SAMPLES=5
# CACHE_EMBED_BACKPRESSURE_WINDOW=50
# CACHE_EMBED_BACKPRESSURE_TTL_SECONDS=30
