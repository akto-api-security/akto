# Server
SERVER_PORT=8080
LOG_LEVEL=info

# Multi-tenant auth — JWT public key from Mongo (same as database-abstractor)
AKTO_OTLP_AUTHENTICATE=true
AKTO_MONGO_CONN=mongodb://localhost:27017/admin
AKTO_MONGO_DB=common
OTLP_KEY_REFRESH_MIN=5
# Optional override for local dev (takes precedence over Mongo)
RSA_PUBLIC_KEY=
# Comma-separated full JWT strings to reject
AKTO_OTLP_REVOKED_TOKENS=

# Pipeline
OTLP_QUEUE_SIZE=50000
OTLP_WORKER_COUNT=8
OTLP_MAX_BATCH_BYTES=4194304

# Logging — never enable in production (prompts/tool params)
OTLP_LOG_SENSITIVE=false

# HTTP server timeouts (seconds)
OTLP_READ_TIMEOUT_SEC=10
OTLP_WRITE_TIMEOUT_SEC=10
OTLP_IDLE_TIMEOUT_SEC=120
OTLP_SHUTDOWN_TIMEOUT_SEC=30

# Phase 2 — per-tenant data-ingestion-service HTTP sink (not wired in Phase 1)
