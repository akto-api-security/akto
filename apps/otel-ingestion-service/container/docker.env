SERVER_PORT=8080
LOG_LEVEL=debug

# Quick local start — no Mongo required
AKTO_OTLP_AUTHENTICATE=false

# For auth testing, run: ../scripts/generate_dev_token.sh && source ../.dev-keys/env.snippet
# Then set AKTO_OTLP_AUTHENTICATE=true and RSA_PUBLIC_KEY from env.snippet

OTLP_QUEUE_SIZE=10000
OTLP_WORKER_COUNT=8
OTLP_MAX_BATCH_BYTES=4194304
OTLP_LOG_SENSITIVE=true
