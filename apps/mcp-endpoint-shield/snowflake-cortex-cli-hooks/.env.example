# Required: Akto data ingestion base URL (no trailing slash)
AKTO_DATA_INGESTION_URL=https://your-akto-ingestion.example.com

# Required for ingestion Authorization header and cyborg heartbeat (same value as Copilot hooks / dashboard)
AKTO_API_TOKEN=

# Optional: cyborg URL for agent heartbeat (SaaS default is https://cyborg.akto.io — set only when self-hosting)
# DATABASE_ABSTRACTOR_SERVICE_URL=https://cyborg.akto.io

# atlas: per-device synthetic host; argus: generic synthetic host
MODE=atlas

# Optional override for Atlas device id (defaults to machine id)
# DEVICE_ID=

AKTO_SYNC_MODE=true
AKTO_TIMEOUT=5

# Connector label sent to Akto http-proxy (keep default unless instructed)
AKTO_CONNECTOR=cortex_code_cli

CONTEXT_SOURCE=ENDPOINT

LOG_DIR=~/.snowflake/cortex/akto/logs
LOG_LEVEL=INFO
