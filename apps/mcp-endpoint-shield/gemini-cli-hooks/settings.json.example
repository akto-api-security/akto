{
  "hooks": {
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "akto-validate-before-agent",
            "type": "command",
            "command": "bash ~/.gemini/hooks/akto-validate-before-agent-wrapper.sh",
            "timeout": 10000,
            "description": "Validates user prompts against Akto Guardrails before the agent plans"
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "akto-validate-before-tool",
            "type": "command",
            "command": "bash ~/.gemini/hooks/akto-validate-before-tool-wrapper.sh",
            "timeout": 10000,
            "description": "Validates tool calls against Akto Guardrails before execution"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "akto-validate-after-tool",
            "type": "command",
            "command": "bash ~/.gemini/hooks/akto-validate-after-tool-wrapper.sh",
            "timeout": 10000,
            "description": "Validates tool results and ingests traffic to Akto"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "akto-validate-after-agent",
            "type": "command",
            "command": "bash ~/.gemini/hooks/akto-validate-after-agent-wrapper.sh",
            "timeout": 10000,
            "description": "Validates agent responses against Akto Guardrails and ingests traffic"
          }
        ]
      }
    ]
  }
}
