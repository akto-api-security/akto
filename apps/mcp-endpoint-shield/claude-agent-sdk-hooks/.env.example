# Akto Agent SDK Hooks — Environment Variables
# Copy to .env and fill in values, or export directly in your environment.

# Required
AKTO_DATA_INGESTION_URL=http://localhost:80
AKTO_API_TOKEN=                         # Authorization header value sent to AKTO_DATA_INGESTION_URL

# Agent identity (server-side — no machine ID used)
AKTO_HOST=api.anthropic.com         # Hostname written into request headers for Akto's HTTP proxy

# Behaviour
AKTO_SYNC_MODE=true                 # true = block on violations; false = observe-only
AKTO_TIMEOUT=5                      # HTTP timeout in seconds
MODE=argus                          # argus (default) or atlas
AKTO_CONNECTOR=claude_agent_sdk     # Source label in Akto

# Tool / MCP classification
AKTO_CONNECTOR_VALUE=claude_agent_sdk   # Client label in tool tags (mcp-client / ai-agent)
MCP_INGEST_PATH=/mcp                    # Mirrored path for MCP tool calls
NON_MCP_TOOL_PATH_PREFIX=/tool          # Path prefix for built-in / non-MCP tools

# Logging
LOG_DIR=~/.claude/akto/logs
LOG_LEVEL=INFO
LOG_PAYLOADS=false                  # Set to true to log full request/response bodies

# SSL (optional)
# SSL_CERT_PATH=/path/to/ca-bundle.crt
