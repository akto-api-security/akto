# Akto Cursor Hooks — Configuration Reference
# Copy relevant lines to your shell profile or .env loader.

# ==========================================
# REQUIRED
# ==========================================

# Akto guardrails/ingestion endpoint
AKTO_DATA_INGESTION_URL=http://localhost:80

# ==========================================
# OPTIONAL: Authentication & Request
# ==========================================

# Bearer token for Akto API calls (sent as Authorization header)
# AKTO_API_TOKEN=

# Request timeout in seconds (default: 5)
# AKTO_TIMEOUT=5

# Run guardrails synchronously and block on result (default: true)
# AKTO_SYNC_MODE=true

# ==========================================
# OPTIONAL: Mode & Device
# ==========================================

# Operation mode: 'argus' (default) or 'atlas' (device-aware endpoint routing)
# MODE=argus

# Device ID for atlas mode (auto-generated from machine if not set)
# DEVICE_ID=

# ==========================================
# OPTIONAL: Cursor / Anthropic API Host Override
# ==========================================

# API URL used for host header construction (default: https://api.anthropic.com)
# API_URL=https://api.anthropic.com

# Connector short-name used for atlas host and tag construction (default: cursor)
# AKTO_CONNECTOR_VALUE=cursor

# ==========================================
# OPTIONAL: SSL
# ==========================================

# Path to custom CA certificate bundle (PEM) for corporate proxies
# SSL_CERT_PATH=/path/to/ca-bundle.pem

# Set false to skip TLS verification — not recommended for production
# SSL_VERIFY=true

# ==========================================
# OPTIONAL: Logging
# ==========================================

# Directory for hook log files (default: ~/.cursor/akto/chat-logs)
# LOG_DIR=~/.cursor/akto/chat-logs

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO

# Log full request/response payloads — for debugging only
# LOG_PAYLOADS=false

# ==========================================
# OPTIONAL: Behaviour
# ==========================================

# Context source tag applied to mirrored traffic (default: ENDPOINT)
# CONTEXT_SOURCE=ENDPOINT

# ==========================================
# OPTIONAL: MCP Tool Mirroring
# ==========================================

# Mirrored path for MCP tool calls (default: /mcp)
# MCP_INGEST_PATH=/mcp
