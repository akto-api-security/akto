{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File %USERPROFILE%\\.cursor\\hooks\\akto\\akto-validate-chat-prompt-wrapper.ps1",
        "type": "command",
        "timeout": 10
      }
    ],
    "afterAgentResponse": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File %USERPROFILE%\\.cursor\\hooks\\akto\\akto-validate-chat-response-wrapper.ps1",
        "type": "command",
        "timeout": 10
      }
    ],
    "preToolUse": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File %USERPROFILE%\\.cursor\\hooks\\akto\\akto-validate-pre-tool-wrapper.ps1",
        "type": "command",
        "timeout": 10
      }
    ],
    "postToolUse": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File %USERPROFILE%\\.cursor\\hooks\\akto\\akto-validate-post-tool-wrapper.ps1",
        "type": "command",
        "timeout": 10
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File %USERPROFILE%\\.cursor\\hooks\\akto\\akto-validate-mcp-request-wrapper.ps1",
        "type": "command",
        "timeout": 10
      }
    ],
    "afterMCPExecution": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File %USERPROFILE%\\.cursor\\hooks\\akto\\akto-validate-mcp-response-wrapper.ps1",
        "type": "command",
        "timeout": 10
      }
    ]
  }
}
