# Akto data ingestion service URL (required)
AKTO_DATA_INGESTION_URL=http://localhost:9091

# Authorization token for Akto service (optional)
AKTO_TOKEN=

# Sync mode: true = block before LLM call, false = observe after (default: true)
AKTO_SYNC_MODE=true

# Guardrails check timeout in seconds (default: 5)
AKTO_TIMEOUT=5
