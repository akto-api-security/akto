# Akto OpenCode Guardrails Configuration

# ==========================================
# REQUIRED
# ==========================================

# Akto data ingestion URL for guardrails API
# This is where validation requests are sent
AKTO_DATA_INGESTION_URL=https://your-akto-instance/guardrails

# ==========================================
# OPTIONAL: OpenCode API Configuration
# ==========================================

# OpenCode API URL (default: https://api.opencode.ai)
# Only change this if using custom OpenCode endpoint in atlas mode
# OPENCODE_API_URL=https://api.opencode.ai

# ==========================================
# OPTIONAL: Mode & Device Configuration
# ==========================================

# Operation mode: 'argus' (default) or 'atlas' (with device tracking)
# MODE=atlas

# Device ID for atlas mode (auto-generated if not provided)
# Only used when MODE=atlas
# DEVICE_ID=my-device-id

# Context source for request classification (default: ENDPOINT)
# CONTEXT_SOURCE=ENDPOINT

# ==========================================
# OPTIONAL: Authentication & Timeout
# ==========================================

# Bearer token for Akto authentication (if required)
# AKTO_TOKEN=your-bearer-token

# Request timeout in seconds (default: 5)
# AKTO_TIMEOUT=5

# ==========================================
# OPTIONAL: Logging
# ==========================================

# Log directory (default: ~/.config/opencode/akto/logs)
# LOG_DIR=~/.config/opencode/akto/logs

# Logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO

# Enable verbose payload logging (default: false)
# WARNING: Only for debugging - logs full request/response payloads
# LOG_PAYLOADS=false
