AKTO_DATA_INGESTION_URL=http://localhost:80
AKTO_TOKEN=                         # Authorization header value sent to AKTO_DATA_INGESTION_URL

AKTO_TIMEOUT=5                              # Optional

CLAUDE_API_URL=https://api.anthropic.com    # Optional

AKTO_SYNC_MODE=true

AKTO_HOST=          # Optional: hostname for request headers (overrides MODE-derived default)
                    # argus mode default: api.anthropic.com
                    # atlas mode default: {DEVICE_ID}.ai-agent.claudecli
