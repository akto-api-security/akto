# Akto Guardrails Plugin for Hermes Agent
# Example environment configuration

# REQUIRED: Akto server URL for guardrails and logging
AKTO_DATA_INGESTION_URL="https://your-akto-instance.com/guardrails"

# OPTIONAL: Plugin behavior
AKTO_SYNC_MODE="true"                    # "true"=blocking mode, "false"=logging only
AKTO_TIMEOUT="5"                          # Request timeout in seconds
AKTO_CONNECTOR="hermes"                  # Connector identifier
AKTO_TOKEN=""                            # Optional: API token for authentication

# OPTIONAL: Logging
LOG_LEVEL="INFO"                         # DEBUG, INFO, WARNING, ERROR
LOG_PAYLOADS="false"                     # Set to "true" for verbose payload logging
LOG_DIR="~/.config/hermes/akto/logs"    # Log directory

# OPTIONAL: Advanced configuration
MODE="argus"                             # "argus" (default) or "atlas" (device-specific)
DEVICE_ID=""                             # Optional: custom device ID for atlas mode
CONTEXT_SOURCE="ENDPOINT"                # Request classification source

# OPTIONAL: SSL/TLS
SSL_VERIFY="true"                        # Set to "false" to disable SSL verification
SSL_CERT_PATH=""                         # Optional: path to custom SSL certificate
