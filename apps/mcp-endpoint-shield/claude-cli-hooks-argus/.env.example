AKTO_DATA_INGESTION_URL=http://localhost:80
AKTO_TOKEN=                              # Authorization header value sent to AKTO_DATA_INGESTION_URL
AKTO_HOST=https://api.anthropic.com      # host header value (argus mode only)

CONTEXT_SOURCE=AGENTIC                   # contextSource + tags["source"] in payloads

AKTO_SYNC_MODE=true
AKTO_TIMEOUT=5
