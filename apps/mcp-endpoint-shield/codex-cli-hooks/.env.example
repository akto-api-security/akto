# Akto Codex CLI Hooks — Configuration Reference
# Copy relevant lines to your shell profile or .env loader.
# Note: the Codex API host is auto-detected from your Codex config; no host override needed.

# ==========================================
# REQUIRED
# ==========================================

# Akto guardrails/ingestion endpoint
AKTO_DATA_INGESTION_URL=http://localhost:9091

# ==========================================
# OPTIONAL: Authentication & Request
# ==========================================

# Bearer token for Akto API calls (sent as Authorization header)
# AKTO_API_TOKEN=

# Request timeout in seconds (default: 5)
# AKTO_TIMEOUT=5

# Run guardrails synchronously and block on result (default: true)
# AKTO_SYNC_MODE=true

# ==========================================
# OPTIONAL: Mode & Device
# ==========================================

# Operation mode: 'argus' (default) or 'atlas' (device-aware endpoint routing)
# MODE=argus

# Device ID for atlas mode (auto-generated from machine if not set)
# DEVICE_ID=

# ==========================================
# OPTIONAL: Logging
# ==========================================

# Directory for hook log files (default: ~/.codex/akto/logs)
# LOG_DIR=~/.codex/akto/logs

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO

# Log full request/response payloads — for debugging only
# LOG_PAYLOADS=false

# ==========================================
# OPTIONAL: Behaviour
# ==========================================

# Context source tag applied to mirrored traffic (default: ENDPOINT)
# CONTEXT_SOURCE=ENDPOINT

# ==========================================
# OPTIONAL: Built-in Tool Mirroring
# ==========================================

# Mirror non-MCP (built-in Bash) tool calls in addition to MCP tool calls (default: false)
# AKTO_INGEST_NON_MCP_TOOLS=false

# Path prefix for built-in tool ingest (default: /tool)
# NON_MCP_TOOL_PATH_PREFIX=/tool

# Ingest path override for non-MCP tools
# NON_MCP_INGEST_PATH=
