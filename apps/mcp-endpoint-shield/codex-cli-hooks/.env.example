AKTO_DATA_INGESTION_URL=http://localhost:9091

AKTO_TOKEN=                                 # Authorization header value sent to AKTO_DATA_INGESTION_URL

AKTO_TIMEOUT=5                              # Optional

AKTO_SYNC_MODE=true

# Built-in Bash tool mirror/ingest (same defaults as claude-cli-hooks mcp hooks).
AKTO_INGEST_NON_MCP_TOOLS=false
# NON_MCP_TOOL_PATH_PREFIX=/tool
# NON_MCP_INGEST_PATH=
