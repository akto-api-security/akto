<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Baseline schema: all collections and indexes for a fresh account DB -->
    <include file="db/changelog/baseline-account.xml"/>

    <!-- Account-scope migrations (run per account). Add .xml files to account/ -->
    <includeAll path="db/changelog/account" errorIfMissingOrEmpty="false" endsWithFilter=".xml"/>

</databaseChangeLog>
