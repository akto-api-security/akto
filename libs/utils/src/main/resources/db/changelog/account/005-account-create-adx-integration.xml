<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:mongodb="http://www.liquibase.org/xml/ns/mongodb"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
        http://www.liquibase.org/xml/ns/mongodb
        http://www.liquibase.org/xml/ns/mongodb/liquibase-mongodb-latest.xsd">

    <!--
        Collection for AdxIntegrationDao (Azure Data Explorer connection config: cluster
        endpoint, database name, AAD tenant/client id, application key). Singleton-per-account
        document, read/written via findOne/updateOne/deleteAll with an empty filter
        (AdxIntegrationAction), so only the default _id index is needed — no secondary indexes.
    -->

    <changeSet id="005-account-create-adx-integration" author="akto">
        <preConditions onFail="MARK_RAN">
            <not>
                <mongodb:collectionExists collectionName="adx_integration"/>
            </not>
        </preConditions>
        <mongodb:createCollection collectionName="adx_integration"/>
        <rollback>
            <mongodb:dropCollection collectionName="adx_integration"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
